{
  "name": "@agentlogs/web",
  "version": "0.1.0",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "bash ../../scripts/check-and-migrate.sh && bun run cf-typegen && vite dev",
    "dev:test": "VITE_USE_TEST_DB=true bun run cf-typegen && vite dev",
    "dev:wrangler": "wrangler dev --local --log-level=debug",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "bun run cf-typegen && bun run build",
    "deploy": "wrangler deploy",
    "cf-typegen": "test -f .env || cp .env.example .env; wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply agentlogs --local",
    "db:migrate:remote": "wrangler d1 migrations apply agentlogs --remote",
    "db:studio": "DB_LOCAL_PATH=$(find $PWD/.wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit 2>/dev/null) bunx drizzle-kit studio --port 4983",
    "db:studio:test": "DB_LOCAL_PATH=$(find $PWD/.wrangler-test/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit 2>/dev/null) bunx drizzle-kit studio --port 4984",
    "db:reset": "rm -rf .wrangler/state && bun run db:migrate",
    "check": "tsgo --project tsconfig.json"
  },
  "dependencies": {
    "@agentlogs/shared": "workspace:*",
    "@base-ui/react": "^1.2.0",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pierre/diffs": "^1.0.11",
    "@react-email/components": "^1.0.8",
    "@sentry/cloudflare": "^10.40.0",
    "@sentry/tanstackstart-react": "^10.40.0",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/react-start": "^1.163.2",
    "ai": "^6.0.103",
    "better-auth": "1.4.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.6",
    "geist": "^1.7.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.1.9",
    "workers-og": "^0.0.27"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.19",
    "@cloudflare/vite-plugin": "^1.25.6",
    "@sentry/vite-plugin": "^4.9.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.69.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  }
}
